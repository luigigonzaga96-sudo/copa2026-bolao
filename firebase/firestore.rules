rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: verifica se é admin checando email ou upn (Microsoft SSO pode usar upn)
    function adminEmails() {
      return ['luigi.gonzaga@db1.com.br', 'bruno.rossmann@db1.com.br', 'jocimar.huss@db1.com.br'];
    }
    function isAdmin() {
      return request.auth != null && (
        (request.auth.token.email != null && (
          request.auth.token.email.lower() in adminEmails() ||
          exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()))
        )) ||
        (request.auth.token.upn   != null && (
          request.auth.token.upn.lower()   in adminEmails() ||
          exists(/databases/$(database)/documents/admins/$(request.auth.token.upn.lower()))
        ))
      );
    }

    // Helper function to get kickoff time as a timestamp, ensuring it is treated as UTC
    function getKickoffTimestamp(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data.ko is timestamp
        ? get(/databases/$(database)/documents/matches/$(matchId)).data.ko
        : (get(/databases/$(database)/documents/matches/$(matchId)).data.ko.matches('.*[Z+-].*')
          ? timestamp.value(get(/databases/$(database)/documents/matches/$(matchId)).data.ko)
          : timestamp.value(get(/databases/$(database)/documents/matches/$(matchId)).data.ko + 'Z'));
    }

    // Rules for Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Subcollection for Predictions/Bets
      match /predictions/{matchId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null 
          && request.auth.uid == userId
          && get(/databases/$(database)/documents/matches/$(matchId)).data.ko != null
          && request.time < getKickoffTimestamp(matchId) - duration.value(30, 'm');
      }
    }

    // Rules for Matches collection (everyone can read, only admin can write)
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Official Match Results (everyone can read, only admin can write)
    match /results/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Invites (everyone can read, only admin can write)
    match /invites/{email} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for API Lock system
    match /system/apifetch {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Rules for Tournament/Knockout stage
    match /torneio/matamata {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Business Units (everyone can read, only admin can write)
    match /businessUnits/{unitId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Admins list (authenticated can read, only admin can write)
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
